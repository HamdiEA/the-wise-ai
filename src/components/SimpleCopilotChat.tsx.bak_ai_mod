import React, { useState } from "react";
import { askDeepSeek, DeepSeekMessage } from "../lib/deepseek";

export default function SimpleCopilotChat() {
  const [messages, setMessages] = useState<DeepSeekMessage[]>([
    { role: "system", content: "You are Wiser, a friendly restaurant assistant. Use the menu to respond." }
  ]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  async function send() {
    if (!input.trim()) return;
    const userMsg: DeepSeekMessage = { role: "user", content: input.trim() };
    const newMessages = [...messages, userMsg];
    setMessages(newMessages);
    setInput("");
    setLoading(true);
    setError(null);
    try {
      const reply = await askDeepSeek(undefined, { messages: newMessages });
      const assistantMsg: DeepSeekMessage = { role: "assistant", content: typeof reply === "string" ? reply : JSON.stringify(reply) };
      setMessages((m) => [...m, assistantMsg]);
    } catch (err: any) {
      setError(String(err?.message || err));
      setMessages((m) => [...m, { role: "assistant", content: "Sorry — I couldn't contact the assistant." }]);
    } finally {
      setLoading(false);
    }
  }

  return (
    <div style={{border: "1px solid #e5e7eb", borderRadius: 8, padding: 16, background: "#fff"}}>
      <div style={{minHeight: 160, maxHeight: 360, overflow: "auto", padding: 8}}>
        {messages.map((m, i) => (
          <div key={i} style={{marginBottom: 8}}>
            <div style={{fontSize: 12, color: "#6b7280"}}>{m.role}</div>
            <div style={{whiteSpace: "pre-wrap"}}>{m.content}</div>
          </div>
        ))}
      </div>

      <div style={{display: "flex", gap: 8, marginTop: 12}}>
        <input
          value={input}
          onChange={(e) => setInput(e.target.value)}
          onKeyDown={(e) => { if (e.key === "Enter") send(); }}
          placeholder="Ask about the menu or ask for recommendations..."
          style={{flex: 1, padding: "8px 10px", borderRadius: 6, border: "1px solid #d1d5db"}}
        />
        <button onClick={send} disabled={loading} style={{padding: "8px 12px", borderRadius: 6, background: "#111827", color: "#fff", border: "none"}}>
          {loading ? "..." : "Send"}
        </button>
      </div>
      {error && <div style={{color: "red", marginTop: 8}}>Error: {error}</div>}
    </div>
  );
}
